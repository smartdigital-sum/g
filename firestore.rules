// ============================================================
//  GyanPlay — Firestore Security Rules
//  Paste these into Firebase Console →
//    Firestore Database → Rules
//  (or run: firebase deploy --only firestore:rules)
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ADMIN CHECK HELPER ──
    // Add your UID to the admins collection in Firestore
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── USER PROFILES ──
    // A user can read/write their OWN profile.
    // Admins can read all profiles (for the admin dashboard).
    match /users/{userId} {
      allow read:   if request.auth != null
                    && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['email','studentName','phone','createdAt']);
      allow update: if request.auth != null && request.auth.uid == userId;

      // ── PURCHASES (subcollection) ──
      // Read: the user themselves, or an admin (admin panel).
      // Write: admins only — the grantAccess Cloud Function uses the
      //   Admin SDK which bypasses these rules, so it still works.
      //   Regular users can never write purchases from the client.
      match /purchases/{classId} {
        allow read:  if request.auth != null
                     && (request.auth.uid == userId || isAdmin());
        allow write: if isAdmin();
      }

      // ── PLAYED GAMES (subcollection) ──
      // A user can read and write their own played-game records
      match /played/{gameId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // ── CLASS CONTENT (games list) ──
    // Any logged-in user can READ class metadata + subjects + games.
    // Only admin can WRITE anywhere under /classes.
    match /classes/{classId}/{document=**} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── ADMINS COLLECTION ──
    // Locked down: only Firebase Console can add admin docs.
    // Reads are guarded by the isAdmin() helper above.
    match /admins/{uid} {
      allow read, write: if false;
    }

  }
}
